# API Keys for Agent Observability Lab
# Copy this file to .env and fill in your API keys

# Anthropic (REQUIRED for Claude Haiku)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Optional: override model (default claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Braintrust (REQUIRED for observability - FREE, no credit card required)
# Sign up and get your FREE key at: https://www.braintrust.dev/
BRAINTRUST_API_KEY=your-braintrust-api-key-here

# Braintrust Project Name (REQUIRED)
# Use the format: project_name:your-project-name
# The project name can be anything relevant to your agent or course project
#
# Examples:
#   Single agent: project_name:simple-agent-observability
#   Course project: project_name:dsan6725-my-cool-final-project
#   Multiple agents in one project: project_name:dsan6725-all-agents
#
# If you have multiple agents that are part of the same bigger project,
# use the same project name for all of them so traces appear in one place
BRAINTRUST_PROJECT=project_name:simple-agent-observability
